{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scope Run State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "state_schema_version",
    "run_id",
    "scope_id",
    "scope_type",
    "scope_path",
    "status",
    "build_system",
    "risk_level",
    "compatibility_status",
    "migration_wave_candidate",
    "automation_eligibility",
    "requires_human_decision",
    "next_action",
    "detected_technologies",
    "evidence_inventory",
    "validation",
    "last_updated"
  ],
  "properties": {
    "state_schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "scope_id": {
      "type": "string",
      "minLength": 1
    },
    "scope_type": {
      "type": "string",
      "enum": [
        "repository",
        "module",
        "service",
        "library",
        "consumer"
      ]
    },
    "scope_path": {
      "type": "string",
      "minLength": 1
    },
    "scope_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "blocked",
        "completed"
      ]
    },
    "build_system": {
      "type": "string",
      "enum": [
        "maven",
        "gradle",
        "mixed",
        "unknown"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical",
        "unknown"
      ]
    },
    "compatibility_status": {
      "type": "string",
      "enum": [
        "compatible",
        "partially_compatible",
        "incompatible",
        "unknown"
      ]
    },
    "migration_wave_candidate": {
      "type": "string",
      "enum": [
        "first_wave",
        "later_wave",
        "blocked",
        "unknown"
      ]
    },
    "automation_eligibility": {
      "type": "string",
      "enum": [
        "openrewrite_ready",
        "manual_only",
        "transformer_exception",
        "unknown"
      ]
    },
    "requires_human_decision": {
      "type": "boolean"
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "detected_technologies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "blocking_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_inventory": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_run",
            "passed",
            "failed"
          ]
        },
        "goal": {
          "type": "string"
        },
        "summary_file": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    }
  }
}
