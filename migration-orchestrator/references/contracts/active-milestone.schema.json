{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Active Milestone State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "state_schema_version",
    "milestone_id",
    "milestone_type",
    "goal",
    "status",
    "wave_id",
    "entry_criteria",
    "exit_criteria",
    "selected_scope_ids",
    "completed_scope_ids",
    "pending_scope_ids",
    "deferred_scope_ids",
    "blocking_decision_ids",
    "success_metrics",
    "artifacts_required",
    "last_updated"
  ],
  "properties": {
    "state_schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "milestone_id": {
      "type": "string",
      "minLength": 1
    },
    "milestone_type": {
      "type": "string",
      "enum": [
        "discovery",
        "planning",
        "execution",
        "stabilization"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "blocked",
        "completed"
      ]
    },
    "wave_id": {
      "type": "string",
      "minLength": 1
    },
    "entry_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exit_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selected_scope_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "completed_scope_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "pending_scope_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "blocked_scope_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "deferred_scope_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "next_scope_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "blocking_decision_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "success_metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    }
  }
}
